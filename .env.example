# ─── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─── Gemini (OCR de screenshots de partidas) ───────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini
VITE_GEMINI_API_KEY=sua_chave_gemini

# ─── Admin master (nunca commitar com valores reais) ───────────────────────────
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=sua_senha_segura

# ─── Pagamentos Pix ────────────────────────────────────────────────────────────
# Chave Pix do organizador principal (CPF, CNPJ, email ou +55celular)
VITE_PIX_KEY=seu@email.com
VITE_PIX_NAME=PRO WORLD ARENA

# ─── Pagamentos Stripe (cartão de crédito/débito) ─────────────────────────────
# Obtenha em https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_sua_chave_publica
# NUNCA expor a chave secreta no frontend — use Edge Functions do Supabase
# STRIPE_SECRET_KEY=sk_test_sua_chave_secreta  # usar apenas no servidor
